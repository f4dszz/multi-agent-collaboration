{
  "name": "default_local_workflow",
  "description": "Local-first workflow for executor, reviewer, verifier and human gate.",
  "roles": [
    "executor",
    "reviewer",
    "verifier",
    "human"
  ],
  "states": [
    "drafting_plan",
    "plan_review",
    "plan_revision",
    "awaiting_plan_approval",
    "implementing",
    "implementation_review",
    "verifying",
    "awaiting_final_approval",
    "completed",
    "blocked"
  ],
  "gates": [
    {
      "name": "plan_gate",
      "state": "awaiting_plan_approval",
      "actor": "human"
    },
    {
      "name": "final_gate",
      "state": "awaiting_final_approval",
      "actor": "human"
    }
  ],
  "verifier_trigger": {
    "revision_threshold": 2,
    "risk_tags": ["database", "security", "concurrency", "architecture"]
  }
}
